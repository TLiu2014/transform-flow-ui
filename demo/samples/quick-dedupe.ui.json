{
  "version": "1.0",
  "pipeline": {
    "name": "quick-dedupe",
    "createdAt": "2026-05-30T00:00:00.000Z",
    "description": "DEDUPE: collapse duplicate rows by key (keep the most recent)."
  },
  "datasets": {
    "signups": {
      "columns": [
        { "name": "email", "type": "string" },
        { "name": "name", "type": "string" },
        { "name": "signup_date", "type": "date" }
      ]
    }
  },
  "stages": [
    {
      "id": "l1",
      "name": "load_signups",
      "type": "LOAD",
      "depends_on": [],
      "inputs": [],
      "output": "signups",
      "operation": { "stageType": "LOAD", "tableName": "signups", "source": "signups.csv" }
    },
    {
      "id": "s1",
      "name": "unique_signups",
      "type": "DEDUPE",
      "depends_on": ["l1"],
      "inputs": ["signups"],
      "output": "unique_signups",
      "operation": {
        "stageType": "DEDUPE",
        "table": "signups",
        "keyColumns": ["email"],
        "keepBy": { "column": "signup_date", "direction": "DESC" }
      }
    }
  ],
  "layout": {
    "nodes": [
      { "id": "l1", "position": { "x": 160, "y": 60 } },
      { "id": "s1", "position": { "x": 160, "y": 220 } }
    ],
    "edges": [{ "id": "e1", "source": "l1", "target": "s1" }]
  }
}
