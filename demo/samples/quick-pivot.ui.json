{
  "version": "1.0",
  "pipeline": {
    "name": "quick-pivot",
    "createdAt": "2026-05-30T00:00:00.000Z",
    "description": "PIVOT: rotate distinct values of a column into new columns."
  },
  "datasets": {
    "quarterly_sales": {
      "columns": [
        { "name": "region", "type": "string" },
        { "name": "quarter", "type": "string" },
        { "name": "revenue", "type": "float" }
      ]
    }
  },
  "stages": [
    {
      "id": "l1",
      "name": "load_quarterly_sales",
      "type": "LOAD",
      "depends_on": [],
      "inputs": [],
      "output": "quarterly_sales",
      "operation": { "stageType": "LOAD", "tableName": "quarterly_sales", "source": "quarterly_sales.csv" }
    },
    {
      "id": "s1",
      "name": "revenue_pivot",
      "type": "PIVOT",
      "depends_on": ["l1"],
      "inputs": ["quarterly_sales"],
      "output": "revenue_pivot",
      "operation": {
        "stageType": "PIVOT",
        "table": "quarterly_sales",
        "indexColumn": "region",
        "columnsColumn": "quarter",
        "valuesColumn": "revenue",
        "aggregation": "SUM"
      }
    }
  ],
  "layout": {
    "nodes": [
      { "id": "l1", "position": { "x": 160, "y": 60 } },
      { "id": "s1", "position": { "x": 160, "y": 220 } }
    ],
    "edges": [{ "id": "e1", "source": "l1", "target": "s1" }]
  }
