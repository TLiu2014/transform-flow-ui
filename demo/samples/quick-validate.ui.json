{
  "version": "1.0",
  "pipeline": {
    "name": "quick-validate",
    "createdAt": "2026-05-30T00:00:00.000Z",
    "description": "VALIDATE: route rows to pass/fail outputs based on rules."
  },
  "datasets": {
    "signups": {
      "columns": [
        { "name": "email", "type": "string" },
        { "name": "age", "type": "integer" },
        { "name": "name", "type": "string" }
      ]
    }
  },
  "stages": [
    {
      "id": "l1",
      "name": "load_signups",
      "type": "LOAD",
      "depends_on": [],
      "inputs": [],
      "output": "signups",
      "operation": { "stageType": "LOAD", "tableName": "signups", "source": "signups.csv" }
    },
    {
      "id": "s1",
      "name": "validate_signups",
      "type": "VALIDATE",
      "depends_on": ["l1"],
      "inputs": ["signups"],
      "output": "clean_signups",
      "operation": {
        "stageType": "VALIDATE",
        "table": "signups",
        "combinator": "AND",
        "rules": [
          { "column": "age", "operator": ">", "value": "0" },
          { "column": "email", "operator": "LIKE", "value": "%@%" }
        ],
        "passOutput": "clean_signups",
        "failOutput": "bad_signups"
      }
    }
  ],
  "layout": {
    "nodes": [
      { "id": "l1", "position": { "x": 160, "y": 60 } },
      { "id": "s1", "position": { "x": 160, "y": 220 } }
    ],
    "edges": [{ "id": "e1", "source": "l1", "target": "s1" }]
  }
}
